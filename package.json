{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:next": "TZ=Etc/UTC next dev --port 1337",
    "dev:graphql": "bun run codegen -- --watch",
    "build": "npm run build:graphql && npm run build:next",
    "build:next": "next build",
    "build:graphql": "bun run codegen",
    "start": "next start",
    "static:lint": "eslint .",
    "static:types": "tsc --noEmit",
    "static": "npm-run-all --parallel static:*",
    "dump-prod": "mongodump --excludeCollection=kilterboard_climbs  --excludeCollection=kilterboard_climb_stats --uri=\"$(npx --yes dotenv-cli -e .env.local -- bash -c 'echo $PROD_MONGODB_URL')\" --out=\"mongodump/$(date '+%Y-%m-%d-%H:%M:%S')\"",
    "restore-local-from-dump": "mongorestore -h 127.0.0.1 --port 27017 --drop --nsFrom=\"self.*\" --nsTo=\"test.*\"",
    "copy-prod": "npm run dump-prod && npm run restore-local-from-dump mongodump/$(ls -Art mongodump | tail -n 1)",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@apollo/client-integration-nextjs": "^0.14.5",
    "@apollo/server": "^5.5.0",
    "@as-integrations/next": "^4.1.0",
    "@auth/mongodb-adapter": "3.11.2",
    "@date-fns/tz": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@googleapis/gmail": "^16.1.1",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@graphql-tools/schema": "^10.0.32",
    "@nivo/line": "^0.99.0",
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/postcss": "^4.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.4.3",
    "ably": "^2.21.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "echarts-for-react": "^3.0.6",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "google-auth-library": "10.5.0",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "graphql-type-json": "^0.3.2",
    "ical-generator": "^10.2.0",
    "luxon": "^3.7.2",
    "mongodb": "^7.2.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "npm-run-all": "^4.1.5",
    "partysocket": "1.1.18",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-apollo-network-status": "^6.0.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "remark-gfm": "^4.0.1",
    "rrule": "^2.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "typescript-eslint": "^8.59.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@serwist/turbopack": "^9.5.7",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dayjs": "^1.11.20",
    "esbuild": "^0.28.0",
    "eslint": "9",
    "partykit": "0.0.115",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serwist": "^9.5.7",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
